		private sealed class Parser : IDisposable\
		\{\
			private enum TOKEN\
			\{\
				NONE,\
				CURLY_OPEN,\
				CURLY_CLOSE,\
				SQUARED_OPEN,\
				SQUARED_CLOSE,\
				COLON,\
				COMMA,\
				STRING,\
				NUMBER,\
				TRUE,\
				FALSE,\
				NULL\
			\}\
