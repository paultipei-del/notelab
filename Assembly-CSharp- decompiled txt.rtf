	public int GetNumStars(float finalTime, ClefType clefs)\
	\{\
		if (finalTime == float.MaxValue)\
		\{\
			return 0;\
		\}\
		for (int num = 6; num >= 1; num--)\
		\{\
			if (finalTime.RoundToNearestMillisecond() <= CalcGoalTime(num, clefs))\
			\{\
				return num;\
			\}\
		\}\
		return 1;\
	\}\
