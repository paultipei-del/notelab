	public float CalcGoalTime(int stars, ClefType clefs)\
	\{\
		float num = 0f;\
		switch (stars)\
		\{\
		case 1:\
			return 0f;\
		case 2:\
			num = LevelConfigs.STAR2_AVG_TIME;\
			break;\
		case 3:\
			num = LevelConfigs.STAR3_AVG_TIME;\
			break;\
		case 4:\
			num = LevelConfigs.STAR4_AVG_TIME;\
			break;\
		case 5:\
			num = LevelConfigs.STAR5_AVG_TIME;\
			break;\
		case 6:\
			num = LevelConfigs.STAR6_AVG_TIME;\
			break;\
		\}\
		num *= (float)NotesCount(clefs);\
