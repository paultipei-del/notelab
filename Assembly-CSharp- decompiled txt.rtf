		\}\
		else\
		\{\
			switch (clef)\
			\{\
			case ClefType.Both:\
				return NotesDeck;\
			case ClefType.Treble:\
			\{\
				string[] notesDeck = NotesDeck;\
				foreach (string text in notesDeck)\
				\{\
					if ((NotationFunctions.GetMidiNoteFromString(text) >= 60 && !text.Contains("b")) || text.Contains("t"))\
					\{\
						for (int k = 0; k < Reps; k++)\
						\{\
							list.Add(text);\
						\}\
					\}\
				\}\
				break;\
			\}\
			\}\
			if (clef == ClefType.Bass)\
			\{\
				string[] notesDeck2 = NotesDeck;\
				foreach (string text2 in notesDeck2)\
				\{\
					if ((NotationFunctions.GetMidiNoteFromString(text2) <= 60 && !text2.Contains("t")) || text2.Contains("b"))\
					\{\
						for (int m = 0; m < Reps; m++)\
						\{\
